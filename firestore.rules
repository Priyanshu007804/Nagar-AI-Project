rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.points is int
        && data.streak is int
        && data.reportedCount is int
        && data.potholeCount is int
        && data.unlockedBadges is list;
    }

    function isValidReport(data) {
      return data.issueType is string && data.issueType.size() <= 100
        && data.location is string && data.location.size() <= 500
        && data.severity is string && data.severity.size() <= 50
        && data.status is string && data.status.size() <= 50
        && data.date is string && data.date.size() <= 50
        && data.reporterId is string && data.reporterId.size() <= 128;
    }

    // Profiles Collection
    match /profiles/{uid} {
      // Anyone can read profiles to populate leaderboards and view user details
      allow read, list: if true;
      
      // Creating a profile requires providing a valid schema (supports both guests and authenticated owners)
      allow create: if isValidUserProfile(request.resource.data);
      
      // Updating a profile requires a valid schema, or only incrementing the points field for report verification
      allow update: if isValidUserProfile(request.resource.data)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']);
      
      // Deleting profiles is forbidden
      allow delete: if false;
    }

    // Reports Collection
    match /reports/{reportId} {
      // Anyone can read reports (dashboard views, interactive maps, public list feeds)
      allow read, list: if true;
      
      // Creating a report is allowed for anyone with valid data (including guests)
      allow create: if isValidReport(request.resource.data);
      
      // Updating a report is allowed with valid data (for status changes or adding verifications)
      allow update: if isValidReport(request.resource.data);
      
      // Deleting reports is forbidden
      allow delete: if false;
    }
  }
}
